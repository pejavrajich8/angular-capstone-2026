{
  "name": "capstone-angular-2026",
  "version": "0.0.0",
  "description": "Workspace root for the capstone Angular frontend and Express backend.",
  "scripts": {
    "start": "npm run start --workspace frontend",
    "build": "npm run build --workspace frontend",
    "watch": "npm run watch --workspace frontend",
    "test": "npm run test --workspace frontend",
    "start:backend": "npm run start --workspace backend",
    "dev:backend": "npm run dev --workspace backend",
    "start:all": "npm run start & npm run start:backend"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "@angular/common": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0"
  }
}
