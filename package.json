{
  "name": "capstone-angular-2026",
  "version": "0.0.0",
  "description": "Workspace root for the capstone Angular frontend and Express backend.",
  "scripts": {
    "start": "npm run start --workspace frontend",
    "build": "npm run build --workspace frontend",
    "watch": "npm run watch --workspace frontend",
    "test": "npm run test --workspace frontend",
    "start:backend": "npm run start --workspace backend",
    "dev:backend": "npm run dev --workspace backend",
    "start:all": "npm run start & npm run start:backend"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "frontend",
    "backend"
  ]
}
