rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document (for currency)
    match /users/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if request.auth.uid == uid;
    }

    // Sports picks - user can read/write their own
    match /sportsPicks/{document} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read other public data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
